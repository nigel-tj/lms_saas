{
 "doctype": "DocType",
 "name": "LMS Survey",
 "module": "Lms Saas",
 "custom": 0,
 "autoname": "format:SUR-{#####}",
 "track_changes": 1,
 "title_field": "title",
 "fields": [
  {
   "fieldname": "title",
   "fieldtype": "Data",
   "label": "Title",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "description",
   "fieldtype": "Text",
   "label": "Description"
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "trigger_event",
   "fieldtype": "Select",
   "label": "Trigger Event",
   "options": "Post-Disbursement\nPost-Collection\nManual",
   "default": "Manual",
   "in_list_view": 1
  },
  {
   "fieldname": "is_active",
   "fieldtype": "Check",
   "label": "Is Active",
   "default": "1",
   "in_list_view": 1
  },
  {
   "fieldname": "section_break_questions",
   "fieldtype": "Section Break",
   "label": "Questions"
  },
  {
   "fieldname": "questions",
   "fieldtype": "Table",
   "label": "Questions",
   "options": "LMS Survey Question"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "export": 1,
   "report": 1
  },
  {
   "role": "LMS Portal Staff",
   "read": 1
  },
  {
   "role": "Customer",
   "read": 1
  }
 ]
}