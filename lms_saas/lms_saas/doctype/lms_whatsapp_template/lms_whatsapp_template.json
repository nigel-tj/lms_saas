{
 "doctype": "DocType",
 "name": "LMS WhatsApp Template",
 "module": "Lms Saas",
 "custom": 0,
 "autoname": "format:WA-TPL-{#####}",
 "track_changes": 1,
 "title_field": "template_name",
 "fields": [
  {
   "fieldname": "template_name",
   "fieldtype": "Data",
   "label": "Template Name",
   "reqd": 1,
   "in_list_view": 1,
   "unique": 1
  },
  {
   "fieldname": "template_body",
   "fieldtype": "Text",
   "label": "Template Body",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "category",
   "fieldtype": "Select",
   "label": "Category",
   "options": "Payment Reminder\nDisbursement Notice\nWelcome\nMarketing\nSupport",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "language",
   "fieldtype": "Data",
   "label": "Language",
   "default": "en"
  },
  {
   "fieldname": "is_approved",
   "fieldtype": "Check",
   "label": "Is Approved",
   "default": "0",
   "in_list_view": 1
  },
  {
   "fieldname": "variables",
   "fieldtype": "Small Text",
   "label": "Variables",
   "description": "Comma-separated variable names (e.g. customer_name, amount, date)"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "export": 1,
   "report": 1
  },
  {
   "role": "LMS Portal Staff",
   "read": 1
  }
 ]
}