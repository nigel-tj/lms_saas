{
 "doctype": "DocType",
 "name": "LMS Regulatory Submission",
 "module": "Lms Saas",
 "custom": 0,
 "autoname": "format:REG-{#####}",
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "report_type",
   "fieldtype": "Select",
   "label": "Report Type",
   "options": "Weekly KPI\nPortfolio At Risk\nArrears Aging\nIFRS9 ECL\nTransaction Summary\nComplaint Summary\nIncident Log",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "period_start",
   "fieldtype": "Date",
   "label": "Period Start",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "period_end",
   "fieldtype": "Date",
   "label": "Period End",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "generated_on",
   "fieldtype": "Datetime",
   "label": "Generated On",
   "default": "Now",
   "in_list_view": 1
  },
  {
   "fieldname": "generated_by",
   "fieldtype": "Link",
   "label": "Generated By",
   "options": "User"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
