   "label": "Attachment & Notes"
  },
  {
   "fieldname": "file_attachment",
   "fieldtype": "Attach",
   "label": "File Attachment"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "Notes"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "export": 1,
   "report": 1
  },
  {
   "role": "LMS Portal Staff",
   "read": 1
  }
 ]
}